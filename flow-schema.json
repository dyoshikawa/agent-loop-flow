{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/dyoshikawa-claw/agent-loop-flow/refs/heads/main/flow-schema.json",
  "title": "Agent Loop Flow Definition",
  "description": "Schema for defining AI agent skill flows with conditionals and loops",
  "type": "object",
  "required": ["name", "steps"],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference for IDE validation and autocompletion"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Name of the flow"
    },
    "description": {
      "type": "string",
      "description": "Human-readable description of what this flow does"
    },
    "version": {
      "type": "string",
      "description": "Version of the flow definition"
    },
    "variables": {
      "type": "object",
      "description": "Default variables available to all steps. Can be overridden at runtime.",
      "additionalProperties": true
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "description": "Ordered list of steps to execute",
      "items": {
        "$ref": "#/definitions/step"
      }
    }
  },
  "additionalProperties": false,
  "definitions": {
    "step": {
      "oneOf": [
        { "$ref": "#/definitions/skillStep" },
        { "$ref": "#/definitions/conditionalStep" },
        { "$ref": "#/definitions/whileLoopStep" },
        { "$ref": "#/definitions/forEachStep" }
      ]
    },
    "skillStep": {
      "type": "object",
      "required": ["type", "name", "skill", "prompt"],
      "properties": {
        "type": {
          "const": "skill",
          "description": "Identifies this as a skill execution step"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable name for this step"
        },
        "skill": {
          "type": "string",
          "minLength": 1,
          "description": "The skill identifier to invoke"
        },
        "prompt": {
          "type": "string",
          "minLength": 1,
          "description": "The prompt to send to the skill. Supports {{variable}} interpolation."
        },
        "config": {
          "type": "object",
          "description": "Optional configuration passed to the skill executor",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "conditionalStep": {
      "type": "object",
      "required": ["type", "name", "condition", "then"],
      "properties": {
        "type": {
          "const": "conditional",
          "description": "Identifies this as a conditional branching step"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable name for this step"
        },
        "condition": {
          "type": "string",
          "minLength": 1,
          "description": "Condition expression to evaluate"
        },
        "then": {
          "type": "array",
          "items": { "$ref": "#/definitions/step" },
          "description": "Steps to execute when condition is true"
        },
        "else": {
          "type": "array",
          "items": { "$ref": "#/definitions/step" },
          "description": "Steps to execute when condition is false"
        }
      },
      "additionalProperties": false
    },
    "whileLoopStep": {
      "type": "object",
      "required": ["type", "name", "condition", "steps"],
      "properties": {
        "type": {
          "const": "while-loop",
          "description": "Identifies this as a while-loop step"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable name for this step"
        },
        "condition": {
          "type": "string",
          "minLength": 1,
          "description": "Condition to evaluate before each iteration"
        },
        "maxIterations": {
          "type": "integer",
          "minimum": 1,
          "description": "Maximum number of iterations (default: 100)"
        },
        "steps": {
          "type": "array",
          "items": { "$ref": "#/definitions/step" },
          "description": "Steps to execute in each iteration"
        }
      },
      "additionalProperties": false
    },
    "forEachStep": {
      "type": "object",
      "required": ["type", "name", "items", "as", "steps"],
      "properties": {
        "type": {
          "const": "for-each",
          "description": "Identifies this as a for-each iteration step"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable name for this step"
        },
        "items": {
          "type": "string",
          "minLength": 1,
          "description": "Variable name containing the array to iterate over"
        },
        "as": {
          "type": "string",
          "minLength": 1,
          "description": "Variable name to bind each item to during iteration"
        },
        "steps": {
          "type": "array",
          "items": { "$ref": "#/definitions/step" },
          "description": "Steps to execute for each item"
        }
      },
      "additionalProperties": false
    }
  }
}
