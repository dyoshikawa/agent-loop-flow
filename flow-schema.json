{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "defaultTool": {
      "$ref": "#/$defs/__schema0"
    },
    "defaultModel": {
      "type": "string",
      "minLength": 1
    },
    "variables": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {}
    },
    "steps": {
      "minItems": 1,
      "type": "array",
      "items": {
        "$ref": "#/$defs/__schema1"
      }
    }
  },
  "required": ["name", "defaultTool", "defaultModel", "steps"],
  "additionalProperties": false,
  "$defs": {
    "__schema0": {
      "anyOf": [
        {
          "type": "string",
          "const": "opencode"
        },
        {
          "type": "string",
          "const": "claude-agent"
        }
      ]
    },
    "__schema1": {
      "anyOf": [
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "skill"
            },
            "name": {
              "type": "string",
              "minLength": 1
            },
            "skill": {
              "type": "string",
              "minLength": 1
            },
            "prompt": {
              "type": "string",
              "minLength": 1
            },
            "config": {
              "type": "object",
              "propertyNames": {
                "type": "string"
              },
              "additionalProperties": {}
            },
            "tool": {
              "$ref": "#/$defs/__schema0"
            },
            "model": {
              "type": "string",
              "minLength": 1
            },
            "next": {
              "anyOf": [
                {
                  "type": "string",
                  "minLength": 1
                },
                {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "condition": {
                        "type": "string",
                        "minLength": 1
                      },
                      "step": {
                        "type": "string",
                        "minLength": 1
                      }
                    },
                    "required": ["step"],
                    "additionalProperties": false
                  }
                }
              ]
            }
          },
          "required": ["type", "name", "skill", "prompt"],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "while-loop"
            },
            "name": {
              "type": "string",
              "minLength": 1
            },
            "condition": {
              "type": "string",
              "minLength": 1
            },
            "maxIterations": {
              "type": "number",
              "minimum": 1
            },
            "steps": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/__schema1"
              }
            }
          },
          "required": ["type", "name", "condition", "steps"],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "for-each"
            },
            "name": {
              "type": "string",
              "minLength": 1
            },
            "items": {
              "type": "string",
              "minLength": 1
            },
            "as": {
              "type": "string",
              "minLength": 1
            },
            "steps": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/__schema1"
              }
            }
          },
          "required": ["type", "name", "items", "as", "steps"],
          "additionalProperties": false
        }
      ]
    }
  },
  "$id": "https://raw.githubusercontent.com/dyoshikawa-claw/agent-loop-flow/refs/heads/main/flow-schema.json",
  "title": "Agent Loop Flow Definition",
  "description": "Schema for defining AI agent skill flows with transitions and loops"
}
