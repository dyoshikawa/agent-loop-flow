{
  // Conditional flow example (flat transition model)
  // Analyzes code, then branches based on the hasIssues variable using next rules.
  // If hasIssues is true  -> fix-issues -> verify-fix (then ends)
  // If hasIssues is false -> report-clean (then ends)
  "$schema": "../flow-schema.json",
  "name": "conditional-fix",
  "description": "Analyze code and conditionally fix issues",
  "version": "1.0.0",
  "defaultTool": "opencode",
  "defaultModel": "github-copilot/claude-opus-4.6",
  "variables": {
    "targetFile": "src/app.ts",
    "hasIssues": true,
  },
  "steps": [
    {
      "type": "prompt",
      "id": "analyze",
      "name": "code-analysis",
      "prompt": "Analyze {{targetFile}} for bugs and code smells",
      "next": [{ "condition": "hasIssues", "step": "fix-issues" }, { "step": "report-clean" }],
    },
    {
      "type": "prompt",
      "id": "fix-issues",
      "name": "code-fix",
      "prompt": "Fix the identified issues in {{targetFile}}:\n{{previousResult.output}}",
      "next": "verify-fix",
    },
    {
      "type": "prompt",
      "id": "verify-fix",
      "name": "test-runner",
      "prompt": "Run tests to verify the fixes in {{targetFile}}",
    },
    {
      "type": "prompt",
      "id": "report-clean",
      "name": "reporter",
      "prompt": "Report that {{targetFile}} has no issues",
    },
  ],
}
