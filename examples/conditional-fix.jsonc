{
  // Conditional flow example
  // Analyzes code, then branches based on whether issues were found
  "$schema": "../flow-schema.json",
  "name": "conditional-fix",
  "description": "Analyze code and conditionally fix issues",
  "version": "1.0.0",
  "variables": {
    "targetFile": "src/app.ts",
    "hasIssues": true,
  },
  "steps": [
    {
      "type": "skill",
      "name": "analyze",
      "skill": "code-analysis",
      "prompt": "Analyze {{targetFile}} for bugs and code smells",
    },
    {
      "type": "conditional",
      "name": "check-issues",
      "condition": "hasIssues",
      "then": [
        {
          "type": "skill",
          "name": "fix-issues",
          "skill": "code-fix",
          "prompt": "Fix the identified issues in {{targetFile}}",
        },
        {
          "type": "skill",
          "name": "verify-fix",
          "skill": "test-runner",
          "prompt": "Run tests to verify the fixes in {{targetFile}}",
        },
      ],
      "else": [
        {
          "type": "skill",
          "name": "report-clean",
          "skill": "reporter",
          "prompt": "Report that {{targetFile}} has no issues",
        },
      ],
    },
  ],
}
