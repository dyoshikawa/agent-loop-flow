{
  // Loop flow example
  // Iterates over a list of files and processes each one
  "$schema": "../flow-schema.json",
  "name": "batch-process",
  "description": "Process multiple files using for-each and while loops",
  "version": "1.0.0",
  "defaultTool": "opencode",
  "defaultModel": "github-copilot/claude-opus-4.6",
  "variables": {
    "files": ["src/a.ts", "src/b.ts", "src/c.ts"],
    "retryEnabled": false,
  },
  "steps": [
    {
      "type": "for-each",
      "id": "process-files",
      "items": "files",
      "as": "currentFile",
      "steps": [
        {
          "type": "prompt",
          "id": "lint-file",
          "name": "linter",
          "prompt": "Lint the file {{currentFile}}",
        },
        {
          "type": "prompt",
          "id": "format-file",
          "name": "formatter",
          "prompt": "Format the file {{currentFile}}",
        },
      ],
    },
    {
      "type": "while-loop",
      "id": "retry-loop",
      "condition": "retryEnabled",
      "maxIterations": 3,
      "steps": [
        {
          "type": "prompt",
          "id": "retry-check",
          "name": "test-runner",
          "prompt": "Re-run failing tests",
        },
      ],
    },
  ],
}
