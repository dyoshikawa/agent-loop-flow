{
  "$schema": "../flow-schema.json",
  "name": "helloworld-flow",
  "description": "Create stdout-helloworld.js file",
  "defaultTool": "opencode",
  "defaultModel": "github-copilot/claude-opus-4.6",
  "steps": [
    {
      "type": "prompt",
      "id": "create-helloworld",
      "name": "code-generator",
      "prompt": "Create a file called stdout-helloworld.js in the current directory that prints 'Hello, World!' to stdout",
    },
  ],
}
